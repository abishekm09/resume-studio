# ─────────────────────────────────────────────────────────────
# AI PROVIDER  —  choose "groq" (free hosted Llama) or "ollama" (local)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=groq

# --- Option A: Groq (recommended) ---------------------------------
# Free API key, no credit card: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option B: Ollama (100% local, no key, no internet) -----------
# Install from https://ollama.com  then:  ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
